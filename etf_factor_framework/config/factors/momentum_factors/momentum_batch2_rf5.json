{
  "name": "动量因子测评-中期回看-batch2-rebalance_freq=5",
  "version": "1.0",
  "description": "动量因子中期回看测评（Y=34,55,89），调仓频率5日",
  "dataset_name": "ETF_Rotation_Daily",
  "data": {
    "csv_path": "../../../etf_rotation_daily.csv",
    "symbol_col": "symbol",
    "date_col": "eob",
    "ohlcv_cols": {
      "open": "open",
      "high": "high",
      "low": "low",
      "close": "close",
      "volume": "volume"
    },
    "start_date": null,
    "end_date": null,
    "min_non_null_ratio": 0.8
  },
  "factors": [
    {"name": "Momentum_o0_l34", "type": "MomentumFactor", "params": {"offset": 0, "lookback": 34}},
    {"name": "Momentum_o1_l34", "type": "MomentumFactor", "params": {"offset": 1, "lookback": 34}},
    {"name": "Momentum_o5_l34", "type": "MomentumFactor", "params": {"offset": 5, "lookback": 34}},
    {"name": "Momentum_o10_l34", "type": "MomentumFactor", "params": {"offset": 10, "lookback": 34}},
    {"name": "Momentum_o20_l34", "type": "MomentumFactor", "params": {"offset": 20, "lookback": 34}},
    {"name": "Momentum_o0_l55", "type": "MomentumFactor", "params": {"offset": 0, "lookback": 55}},
    {"name": "Momentum_o1_l55", "type": "MomentumFactor", "params": {"offset": 1, "lookback": 55}},
    {"name": "Momentum_o5_l55", "type": "MomentumFactor", "params": {"offset": 5, "lookback": 55}},
    {"name": "Momentum_o10_l55", "type": "MomentumFactor", "params": {"offset": 10, "lookback": 55}},
    {"name": "Momentum_o20_l55", "type": "MomentumFactor", "params": {"offset": 20, "lookback": 55}},
    {"name": "Momentum_o0_l89", "type": "MomentumFactor", "params": {"offset": 0, "lookback": 89}},
    {"name": "Momentum_o1_l89", "type": "MomentumFactor", "params": {"offset": 1, "lookback": 89}},
    {"name": "Momentum_o5_l89", "type": "MomentumFactor", "params": {"offset": 5, "lookback": 89}},
    {"name": "Momentum_o10_l89", "type": "MomentumFactor", "params": {"offset": 10, "lookback": 89}},
    {"name": "Momentum_o20_l89", "type": "MomentumFactor", "params": {"offset": 20, "lookback": 89}}
  ],
  "mapper": {
    "type": "rank_based",
    "params": {
      "top_k": 5,
      "direction": -1,
      "weight_method": "equal"
    }
  },
  "evaluation": {
    "forward_period": 5,
    "periods_per_year": 252,
    "risk_free_rate": 0.03,
    "commission_rate": 0.0002,
    "slippage_rate": 0.0,
    "delay": 1,
    "rebalance_freq": 5
  },
  "storage": {
    "storage_mode": "database",
    "db_path": "E:\\code_project\\factor_eval_result\\factor_eval.db",
    "base_path": "E:\\code_project\\factor_eval_result\\etf",
    "save_metrics": true,
    "save_config": true,
    "save_report": true,
    "save_plots": true,
    "save_comparison": true
  }
}
