{
  "name": "动量因子测评-短期回看-batch1-rebalance_freq=5",
  "version": "1.0",
  "description": "动量因子短期回看测评（Y=2,5,8,13,21），调仓频率5日",
  "dataset_name": "ETF_Rotation_Daily",
  "data": {
    "csv_path": "../../../etf_rotation_daily.csv",
    "symbol_col": "symbol",
    "date_col": "eob",
    "ohlcv_cols": {
      "open": "open",
      "high": "high",
      "low": "low",
      "close": "close",
      "volume": "volume"
    },
    "start_date": null,
    "end_date": null,
    "min_non_null_ratio": 0.8
  },
  "factors": [
    {"name": "Momentum_o0_l2", "type": "MomentumFactor", "params": {"offset": 0, "lookback": 2}},
    {"name": "Momentum_o1_l2", "type": "MomentumFactor", "params": {"offset": 1, "lookback": 2}},
    {"name": "Momentum_o5_l2", "type": "MomentumFactor", "params": {"offset": 5, "lookback": 2}},
    {"name": "Momentum_o10_l2", "type": "MomentumFactor", "params": {"offset": 10, "lookback": 2}},
    {"name": "Momentum_o20_l2", "type": "MomentumFactor", "params": {"offset": 20, "lookback": 2}},
    {"name": "Momentum_o0_l5", "type": "MomentumFactor", "params": {"offset": 0, "lookback": 5}},
    {"name": "Momentum_o1_l5", "type": "MomentumFactor", "params": {"offset": 1, "lookback": 5}},
    {"name": "Momentum_o5_l5", "type": "MomentumFactor", "params": {"offset": 5, "lookback": 5}},
    {"name": "Momentum_o10_l5", "type": "MomentumFactor", "params": {"offset": 10, "lookback": 5}},
    {"name": "Momentum_o20_l5", "type": "MomentumFactor", "params": {"offset": 20, "lookback": 5}},
    {"name": "Momentum_o0_l8", "type": "MomentumFactor", "params": {"offset": 0, "lookback": 8}},
    {"name": "Momentum_o1_l8", "type": "MomentumFactor", "params": {"offset": 1, "lookback": 8}},
    {"name": "Momentum_o5_l8", "type": "MomentumFactor", "params": {"offset": 5, "lookback": 8}},
    {"name": "Momentum_o10_l8", "type": "MomentumFactor", "params": {"offset": 10, "lookback": 8}},
    {"name": "Momentum_o20_l8", "type": "MomentumFactor", "params": {"offset": 20, "lookback": 8}},
    {"name": "Momentum_o0_l13", "type": "MomentumFactor", "params": {"offset": 0, "lookback": 13}},
    {"name": "Momentum_o1_l13", "type": "MomentumFactor", "params": {"offset": 1, "lookback": 13}},
    {"name": "Momentum_o5_l13", "type": "MomentumFactor", "params": {"offset": 5, "lookback": 13}},
    {"name": "Momentum_o10_l13", "type": "MomentumFactor", "params": {"offset": 10, "lookback": 13}},
    {"name": "Momentum_o20_l13", "type": "MomentumFactor", "params": {"offset": 20, "lookback": 13}},
    {"name": "Momentum_o0_l21", "type": "MomentumFactor", "params": {"offset": 0, "lookback": 21}},
    {"name": "Momentum_o1_l21", "type": "MomentumFactor", "params": {"offset": 1, "lookback": 21}},
    {"name": "Momentum_o5_l21", "type": "MomentumFactor", "params": {"offset": 5, "lookback": 21}},
    {"name": "Momentum_o10_l21", "type": "MomentumFactor", "params": {"offset": 10, "lookback": 21}},
    {"name": "Momentum_o20_l21", "type": "MomentumFactor", "params": {"offset": 20, "lookback": 21}}
  ],
  "mapper": {
    "type": "rank_based",
    "params": {
      "top_k": 5,
      "direction": -1,
      "weight_method": "equal"
    }
  },
  "evaluation": {
    "forward_period": 5,
    "periods_per_year": 252,
    "risk_free_rate": 0.03,
    "commission_rate": 0.0002,
    "slippage_rate": 0.0,
    "delay": 1,
    "rebalance_freq": 5
  },
  "storage": {
    "storage_mode": "database",
    "db_path": "E:\\code_project\\factor_eval_result\\factor_eval.db",
    "base_path": "E:\\code_project\\factor_eval_result\\etf",
    "save_metrics": true,
    "save_config": true,
    "save_report": true,
    "save_plots": true,
    "save_comparison": true
  }
}
