{
  "name": "动量因子测评-长期回看-batch3-rebalance_freq=10",
  "version": "1.0",
  "description": "动量因子长期回看测评（Y=144），调仓频率10日",
  "dataset_name": "ETF_Rotation_Daily",
  "data": {
    "csv_path": "../../../etf_rotation_daily.csv",
    "symbol_col": "symbol",
    "date_col": "eob",
    "ohlcv_cols": {
      "open": "open",
      "high": "high",
      "low": "low",
      "close": "close",
      "volume": "volume"
    },
    "start_date": null,
    "end_date": null,
    "min_non_null_ratio": 0.8
  },
  "factors": [
    {"name": "Momentum_o0_l144", "type": "MomentumFactor", "params": {"offset": 0, "lookback": 144}},
    {"name": "Momentum_o1_l144", "type": "MomentumFactor", "params": {"offset": 1, "lookback": 144}},
    {"name": "Momentum_o5_l144", "type": "MomentumFactor", "params": {"offset": 5, "lookback": 144}},
    {"name": "Momentum_o10_l144", "type": "MomentumFactor", "params": {"offset": 10, "lookback": 144}},
    {"name": "Momentum_o20_l144", "type": "MomentumFactor", "params": {"offset": 20, "lookback": 144}}
  ],
  "mapper": {
    "type": "rank_based",
    "params": {
      "top_k": 5,
      "direction": -1,
      "weight_method": "equal"
    }
  },
  "evaluation": {
    "forward_period": 10,
    "periods_per_year": 252,
    "risk_free_rate": 0.03,
    "commission_rate": 0.0002,
    "slippage_rate": 0.0,
    "delay": 1,
    "rebalance_freq": 10
  },
  "storage": {
    "storage_mode": "database",
    "db_path": "E:\\code_project\\factor_eval_result\\factor_eval.db",
    "base_path": "E:\\code_project\\factor_eval_result\\etf",
    "save_metrics": true,
    "save_config": true,
    "save_report": true,
    "save_plots": true,
    "save_comparison": true
  }
}
