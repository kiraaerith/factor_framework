{
  "name": "CTC高成交量日收益率之和因子测评",
  "version": "1.0",
  "description": "测试HighVolReturnSum因子，window=20，top_pct=0.2，评估高成交量日收益率之和的预测能力",
  "data": {
    "csv_path": "../../../../etf_rotation_daily.csv",
    "symbol_col": "symbol",
    "date_col": "eob",
    "ohlcv_cols": {
      "open": "open",
      "high": "high",
      "low": "low",
      "close": "close",
      "volume": "volume"
    },
    "start_date": null,
    "end_date": null,
    "min_non_null_ratio": 0.8
  },
  "factors": [
    {
      "name": "HighVolReturnSum_20_20pct",
      "type": "HighVolReturnSum",
      "params": {
        "window": 20,
        "top_pct": 0.2
      }
    }
  ],
  "mapper": {
    "type": "rank_based",
    "params": {
      "top_k": 5,
      "direction": 1,
      "weight_method": "equal"
    }
  },
  "evaluation": {
    "forward_period": 5,
    "periods_per_year": 252,
    "risk_free_rate": 0.03,
    "commission_rate": 0.0002,
    "slippage_rate": 0.0,
    "delay": 1,
    "rebalance_freq": 1,
    "metrics_to_calculate": ["ic", "returns", "risk", "risk_adjusted", "turnover"]
  },
  "storage": {
    "base_path": "E:\\code_project\\factor_eval_result\\etf\\ctc",
    "save_metrics": true,
    "save_config": true,
    "save_report": true,
    "save_plots": true,
    "save_comparison": true
  }
}
