{
  "name": "RSI因子测试-数据库存储模式",
  "version": "1.0",
  "description": "RSI因子回测评估 - 结果保存到SQLite数据库，适合大规模因子评估",
  "dataset_name": "ETF_Rotation_Daily",
  "data": {
    "csv_path": "../../../etf_rotation_daily.csv",
    "symbol_col": "symbol",
    "date_col": "eob",
    "ohlcv_cols": {
      "open": "open",
      "high": "high",
      "low": "low",
      "close": "close",
      "volume": "volume"
    },
    "start_date": null,
    "end_date": null,
    "min_non_null_ratio": 0.8
  },
  "factors": [
    {
      "name": "RSI_14",
      "type": "RSI",
      "params": {
        "period": 14,
        "field": "close"
      }
    }
  ],
  "mapper": {
    "type": "rank_based",
    "params": {
      "top_k": 5,
      "direction": -1,
      "weight_method": "equal"
    }
  },
  "evaluation": {
    "forward_period": 5,
    "periods_per_year": 252,
    "risk_free_rate": 0.03,
    "commission_rate": 0.0002,
    "slippage_rate": 0.0,
    "delay": 1,
    "rebalance_freq": 1
  },
  "storage": {
    "storage_mode": "database",
    "db_path": "E:\\code_project\\factor_eval_result\\factor_eval.db",
    "base_path": "E:\\code_project\\factor_eval_result\\etf",
    "save_metrics": true,
    "save_config": true,
    "save_report": true,
    "save_plots": true,
    "save_comparison": true
  }
}
