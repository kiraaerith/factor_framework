{
  "name": "HighVolChangeAmplitude-因子测评-batch1-rebalance_freq=10",
  "version": "1.0",
  "description": "放量日振幅均值因子测评，批次1（超参1-5），调仓频率10日。取过去window日中成交量变化最高的top_pct比例交易日，计算这些放量日的日振幅均值。",
  "dataset_name": "ETF_Rotation_Daily",
  "data": {
    "csv_path": "E:/iCloudDrive/Desktop/code_project_win/etf_cross_ml/etf_rotation_daily.csv",
    "symbol_col": "symbol",
    "date_col": "eob",
    "ohlcv_cols": {
      "open": "open",
      "high": "high",
      "low": "low",
      "close": "close",
      "volume": "volume"
    },
    "start_date": null,
    "end_date": null,
    "min_non_null_ratio": 0.8
  },
  "factors": [
    {
      "name": "HighVolChangeAmplitude_w20_p0.1",
      "type": "HighVolChangeAmplitude",
      "params": {"window": 20, "top_pct": 0.1}
    },
    {
      "name": "HighVolChangeAmplitude_w20_p0.2",
      "type": "HighVolChangeAmplitude",
      "params": {"window": 20, "top_pct": 0.2}
    },
    {
      "name": "HighVolChangeAmplitude_w20_p0.3",
      "type": "HighVolChangeAmplitude",
      "params": {"window": 20, "top_pct": 0.3}
    },
    {
      "name": "HighVolChangeAmplitude_w40_p0.1",
      "type": "HighVolChangeAmplitude",
      "params": {"window": 40, "top_pct": 0.1}
    },
    {
      "name": "HighVolChangeAmplitude_w40_p0.2",
      "type": "HighVolChangeAmplitude",
      "params": {"window": 40, "top_pct": 0.2}
    }
  ],
  "mapper": {
    "type": "rank_based",
    "params": {
      "top_k": 5,
      "direction": -1,
      "weight_method": "equal"
    }
  },
  "evaluation": {
    "forward_period": 10,
    "periods_per_year": 252,
    "risk_free_rate": 0.03,
    "commission_rate": 0.0002,
    "slippage_rate": 0.0,
    "delay": 1,
    "rebalance_freq": 10
  },
  "storage": {
    "storage_mode": "database",
    "db_path": "E:\\code_project\\factor_eval_result\\factor_eval.db",
    "base_path": "E:\\code_project\\factor_eval_result\\etf",
    "save_metrics": true,
    "save_config": true,
    "save_report": true,
    "save_plots": true,
    "save_comparison": true
  }
}
